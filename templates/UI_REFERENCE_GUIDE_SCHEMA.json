{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "UI Reference Guide",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "guideVersion",
    "slug",
    "title",
    "objective",
    "sources",
    "coverageSummary",
    "pages",
    "tokens",
    "components",
    "interactions",
    "responsiveBehavior",
    "implementationConstraints",
    "unknowns"
  ],
  "properties": {
    "guideVersion": {
      "type": "string"
    },
    "slug": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "type",
          "label",
          "location",
          "purpose",
          "accessStatus"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "website",
              "figma",
              "screenshot",
              "recording",
              "other"
            ]
          },
          "label": {
            "type": "string"
          },
          "location": {
            "type": "string"
          },
          "purpose": {
            "type": "string"
          },
          "accessStatus": {
            "type": "string",
            "enum": [
              "confirmed",
              "partial",
              "blocked",
              "not_checked"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "coverageSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "highConfidence",
        "mediumConfidence",
        "lowConfidence"
      ],
      "properties": {
        "highConfidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mediumConfidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lowConfidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "name",
          "goal",
          "viewports",
          "states"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "goal": {
            "type": "string"
          },
          "viewports": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "desktop",
                "tablet",
                "mobile"
              ]
            }
          },
          "states": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "default",
                "hover",
                "focus",
                "active",
                "disabled",
                "loading",
                "empty",
                "error"
              ]
            }
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "tokens": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "typography",
        "colors",
        "spacing",
        "radii",
        "elevation"
      ],
      "properties": {
        "typography": {
          "$ref": "#/$defs/tokenList"
        },
        "colors": {
          "$ref": "#/$defs/tokenList"
        },
        "spacing": {
          "$ref": "#/$defs/tokenList"
        },
        "radii": {
          "$ref": "#/$defs/tokenList"
        },
        "elevation": {
          "$ref": "#/$defs/tokenList"
        }
      }
    },
    "components": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/component"
      }
    },
    "interactions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/interaction"
      }
    },
    "responsiveBehavior": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "viewport",
          "behavior",
          "evidence",
          "confidence"
        ],
        "properties": {
          "viewport": {
            "type": "string",
            "enum": [
              "desktop",
              "tablet",
              "mobile"
            ]
          },
          "behavior": {
            "type": "string"
          },
          "evidence": {
            "$ref": "#/$defs/evidenceLevel"
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          },
          "sourceIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "implementationConstraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "mustPreserve",
        "acceptableAdaptations",
        "blockedDetails"
      ],
      "properties": {
        "mustPreserve": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptableAdaptations": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blockedDetails": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "impact",
          "status"
        ],
        "properties": {
          "question": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "partially_resolved",
              "blocked",
              "accepted_unknown"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "evidenceLevel": {
      "type": "string",
      "enum": [
        "observed",
        "inferred",
        "unknown"
      ]
    },
    "confidence": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low"
      ]
    },
    "tokenList": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "value",
          "evidence",
          "confidence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "value": {
            "type": "string"
          },
          "unit": {
            "type": "string"
          },
          "sourceIds": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "evidence": {
            "$ref": "#/$defs/evidenceLevel"
          },
          "confidence": {
            "$ref": "#/$defs/confidence"
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "purpose",
        "states",
        "evidence",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "sourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "states": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "coverageStatus"
            ],
            "properties": {
              "name": {
                "type": "string",
                "enum": [
                  "default",
                  "hover",
                  "focus",
                  "active",
                  "disabled",
                  "loading",
                  "empty",
                  "error"
                ]
              },
              "coverageStatus": {
                "type": "string",
                "enum": [
                  "confirmed",
                  "partial",
                  "blocked",
                  "not_checked"
                ]
              },
              "notes": {
                "type": "string"
              }
            }
          }
        },
        "evidence": {
          "$ref": "#/$defs/evidenceLevel"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "trigger",
        "effect",
        "implementationCertainty",
        "evidence",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string"
        },
        "trigger": {
          "type": "string",
          "enum": [
            "load",
            "hover",
            "focus",
            "click",
            "scroll",
            "drag",
            "route_change",
            "modal_open",
            "other"
          ]
        },
        "effect": {
          "type": "string"
        },
        "timingEstimate": {
          "type": "string"
        },
        "sequence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "sourceIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "implementationCertainty": {
          "type": "string",
          "enum": [
            "exact",
            "approximate",
            "behavior_only"
          ]
        },
        "evidence": {
          "$ref": "#/$defs/evidenceLevel"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
